{
  "name": "@asepharyana/elysia",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "db:generate": "bun run drizzle-kit generate",
    "db:migrate": "bun run drizzle-kit migrate",
    "db:push": "bun run drizzle-kit push",
    "db:studio": "bun run drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@sinclair/typebox": "^0.34.49",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "minio": "^8.0.7",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.4",
    "p-limit": "^7.3.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/winston": "^2.4.4",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "typescript": "^5"
  }
}
